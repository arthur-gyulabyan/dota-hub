{
  "$schema": "https://app.qlerify.com/schemas/domain-model/v1.json",
  "version": 1,
  "boundedContext": "Draft Analysis",
  "roles": [
    "User",
    "System"
  ],
  "domainEvents": {
    "DraftSubmitted": {
      "event": "Draft Submitted",
      "role": "User",
      "follows": [
        "start"
      ],
      "command": {
        "$ref": "#/schemas/commands/SubmitDraft"
      },
      "aggregateRoot": {
        "$ref": "#/schemas/entities/DraftState"
      },
      "acceptanceCriteria": [
        "Given the user is on the hero selection page, When they select their team, allied heroes, and enemy heroes and hit Analyze, Then a draft state is created and analysis begins"
      ]
    },
    "DraftAnalyzed": {
      "event": "Draft Analyzed",
      "role": "System",
      "group": "Analysis",
      "follows": [
        {
          "$ref": "#/domainEvents/DraftSubmitted"
        }
      ],
      "command": {
        "$ref": "#/schemas/commands/AnalyzeDraft"
      },
      "aggregateRoot": {
        "$ref": "#/schemas/entities/HeroRecommendation"
      },
      "readModels": [
        {
          "$ref": "#/schemas/queries/GetRecommendationsByDraft",
          "array": true,
          "description": "Get Recommendations By Draft"
        }
      ],
      "acceptanceCriteria": [
        "Given a draft has been submitted, When the system analyzes counters, synergies, and meta data via LLM, Then hero recommendations with reasoning and confidence scores are generated"
      ]
    }
  },
  "schemas": {
    "commands": {
      "SubmitDraft": {
        "required": [
          "userTeam",
          "alliedPicks",
          "enemyPicks"
        ],
        "fields": [
          {
            "name": "id",
            "hideInForm": true
          },
          {
            "name": "userTeam",
            "hideInForm": false
          },
          {
            "name": "alliedPicks",
            "hideInForm": false
          },
          {
            "name": "enemyPicks",
            "hideInForm": false
          }
        ]
      },
      "AnalyzeDraft": {
        "required": [
          "draftStateId"
        ],
        "fields": [
          {
            "name": "id",
            "hideInForm": true
          },
          {
            "name": "draftStateId",
            "hideInForm": false
          }
        ]
      }
    },
    "queries": {
      "GetRecommendationsByDraft": {
        "entity": {
          "$ref": "#/schemas/entities/HeroRecommendation"
        },
        "fields": [
          {
            "name": "draftStateId",
            "isFilter": true
          },
          {
            "name": "heroName"
          },
          {
            "name": "reasoning"
          },
          {
            "name": "confidence"
          },
          {
            "name": "role"
          }
        ]
      }
    },
    "entities": {
      "DraftState": {
        "required": [
          "id",
          "userTeam",
          "alliedPicks",
          "enemyPicks"
        ],
        "fields": [
          {
            "name": "id",
            "description": "Unique identifier",
            "exampleData": [
              "ds-001",
              "ds-002",
              "ds-003"
            ],
            "dataType": "string"
          },
          {
            "name": "userTeam",
            "description": "Which team the user is on",
            "exampleData": [
              "radiant",
              "dire",
              "radiant"
            ],
            "dataType": "string"
          },
          {
            "name": "alliedPicks",
            "description": "Heroes picked by the allied team (JSON array)",
            "exampleData": [
              "[\"Anti-Mage\", \"Crystal Maiden\"]",
              "[\"Pudge\", \"Invoker\", \"Lion\"]",
              "[\"Juggernaut\"]"
            ],
            "dataType": "string"
          },
          {
            "name": "enemyPicks",
            "description": "Heroes picked by the enemy team (JSON array)",
            "exampleData": [
              "[\"Phantom Lancer\", \"Dazzle\"]",
              "[\"Storm Spirit\", \"Rubick\"]",
              "[\"Medusa\", \"Treant Protector\", \"Mars\"]"
            ],
            "dataType": "string"
          }
        ]
      },
      "HeroRecommendation": {
        "required": [
          "id",
          "draftStateId",
          "heroName",
          "reasoning",
          "confidence",
          "role"
        ],
        "fields": [
          {
            "name": "id",
            "description": "Unique identifier",
            "exampleData": [
              "rec-001",
              "rec-002",
              "rec-003"
            ],
            "dataType": "string"
          },
          {
            "name": "draftStateId",
            "description": "Reference to the analyzed draft",
            "exampleData": [
              "ds-001",
              "ds-002",
              "ds-003"
            ],
            "dataType": "string"
          },
          {
            "name": "heroName",
            "description": "Recommended hero name",
            "exampleData": [
              "Earthshaker",
              "Shadow Fiend",
              "Witch Doctor"
            ],
            "dataType": "string"
          },
          {
            "name": "reasoning",
            "description": "LLM explanation for why this hero is a good pick",
            "exampleData": [
              "Strong AoE counter to PL illusions",
              "High mid-game damage against squishy lineup",
              "Good synergy with allied stun-heavy draft"
            ],
            "dataType": "string"
          },
          {
            "name": "confidence",
            "description": "Confidence score 0-100",
            "exampleData": [
              "92",
              "85",
              "78"
            ],
            "dataType": "number"
          },
          {
            "name": "role",
            "description": "Suggested role for the hero",
            "exampleData": [
              "carry",
              "midlane",
              "support"
            ],
            "dataType": "string"
          }
        ]
      }
    }
  },
  "groups": [
    {
      "name": "Selection",
      "startSlotX": 0
    },
    {
      "name": "Analysis",
      "startSlotX": 1
    }
  ],
  "releases": []
}
